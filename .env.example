BOT_TOKEN=your_bot_token_here
ADMIN_ID=your_admin_id_here
CHANNEL_ID=your_channel_id_here
DATABASE_URL=postgresql://user:password@localhost:5432/subscription_bot
WEBHOOK_HOST=https://your-domain.com
# Optional on most hosts: if set by platform, it overrides WEBHOOK_PORT
PORT=8443
WEBHOOK_PORT=8443
WEBHOOK_PATH=/notification_url

# Robokassa
ROBOKASSA_MERCHANT_LOGIN=your_merchant_login
ROBOKASSA_PASSWORD_1=your_password_1
ROBOKASSA_PASSWORD_2=your_password_2
# Optional, only if you use separate test payment button
ROBOKASSA_TEST_PASSWORD_1=your_test_password_1
ROBOKASSA_TEST_PASSWORD_2=your_test_password_2
# 0 = production payments by default, 1 = test payments by default
ROBOKASSA_IS_TEST=0
ROBOKASSA_API_BASE=https://auth.robokassa.kz/Merchant/Index.aspx

# Subscription
SUBSCRIPTION_PRICE=150.00
